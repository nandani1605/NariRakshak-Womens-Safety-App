<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3E5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tips_main_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#311B92"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- SECRET SHORTCUT CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:elevation="8dp"
            app:cardBackgroundColor="#FFF3E0"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_shortcut_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_shortcut_desc"
                    android:textSize="16sp"
                    android:textColor="#424242"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tips Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:elevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_defense_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_defense_desc"
                    android:textSize="16sp"
                    android:textColor="#424242"
                    android:lineSpacingExtra="6dp"
                    android:padding="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tips_video_heading"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#311B92"
            android:layout_marginBottom="12dp"
            android:gravity="center"/>

        <!-- Video 1 Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">
            <ImageView
                android:id="@+id/img_thumbnail_1"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="#000000"
                android:contentDescription="Video Thumbnail 1"/>
        </androidx.cardview.widget.CardView>

        <!-- Video 2 Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">
            <ImageView
                android:id="@+id/img_thumbnail_2"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="#000000"
                android:contentDescription="Video Thumbnail 2"/>
        </androidx.cardview.widget.CardView>

        <!-- Video 3 Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">
            <ImageView
                android:id="@+id/img_thumbnail_3"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="#000000"
                android:contentDescription="Video Thumbnail 3"/>
        </androidx.cardview.widget.CardView>

        <!-- Video 4 Card (Shorts) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp">
            <ImageView
                android:id="@+id/img_thumbnail_4"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="#000000"
                android:contentDescription="Video Thumbnail 4"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>