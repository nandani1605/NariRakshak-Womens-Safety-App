<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center"
        android:background="#80F3E5F5">

        <Button
            android:id="@+id/btnFindPolice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/map_btn_police"
            android:backgroundTint="#311B92"
            android:layout_marginEnd="5dp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnFindHospitals"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/map_btn_hospital"
            android:backgroundTint="#311B92"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnClearRoute"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="16dp"
        android:text="✖"
        android:textSize="18sp"
        android:padding="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:backgroundTint="#D32F2F"
        app:cornerRadius="25dp"
        android:textColor="#FFFFFF"
        android:visibility="gone"
        android:elevation="8dp"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvPlacesList"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_alignParentBottom="true"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:layout_margin="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/map_title_nearest"
                android:padding="12dp"
                android:textStyle="bold"
                android:textColor="#311B92"
                android:gravity="center"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlaces"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>